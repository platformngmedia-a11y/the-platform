{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "crons": [
    { "path": "/api/cron/fetch-sources", "schedule": "0 */2 * * *" },
    { "path": "/api/cron/fetch-sports",  "schedule": "0 */6 * * *" },
    { "path": "/api/cron/health-check",  "schedule": "0 2 * * 0" },
    { "path": "/api/cron/cleanup",       "schedule": "0 3 * * 1" }
  ]
}
